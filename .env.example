# Copy this file to .env and fill in the values before running in production.
# For local development the defaults in settings.py are sufficient.

DJANGO_SETTINGS_MODULE=e_movers.settings
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default is SQLite for dev; switch to Postgres for production)
# DATABASE_URL=postgres://user:password@localhost:5432/e_movers

# CORS — set to your Next.js frontend origin in production
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT lifetimes
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: use an App Password — NOT your regular account password.
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mwapaul265@gmail.com
EMAIL_HOST_PASSWORD=fekb lain znos ifly
DEFAULT_FROM_EMAIL=mwapaul265@gmail.com
